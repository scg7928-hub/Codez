{
  "version": 2,
  "installCommand": "npm i -g pnpm@9 && /vercel/.npm-global/bin/pnpm install",
  "buildCommand": "/vercel/.npm-global/bin/pnpm --filter @workspace/api-server run build && /vercel/.npm-global/bin/pnpm --filter @workspace/codez run build",
  "outputDirectory": "frontend/dist/public",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index"
    }
  ],
  "env": {
    "BASE_PATH": "/",
    "NODE_ENV": "production"
  }
}
